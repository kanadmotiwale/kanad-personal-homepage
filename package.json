  "repository": {
    "type": "git",
    "url": "https://github.com/kanadmotiwale/personal-homepage.git"
  },
  "bugs": {
    "url": "https://github.com/kanadmotiwale/personal-homepage/issues"
  },
  "homepage": "https://kanadmotiwale.github.io/personal-homepage",
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "live-server": "^1.2.2"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
