  "version": "1.0.0",
  "description": "Personal homepage showcasing my software engineering journey",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "start": "live-server . --port=3000 --open=/html/index.html",
    "dev": "live-server . --port=3000",
    "lint": "eslint js/**/*.js",
    "lint:fix": "eslint js/**/*.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "echo 'Static site - no build needed'",
    "deploy": "echo 'Ready to deploy to GitHub Pages'"
  },
  "keywords": [
    "portfolio",
